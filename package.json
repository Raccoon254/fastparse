{
  "name": "fastparse",
  "version": "0.0.1",
  "description": "Fetch a web page and get back the actual content as JSON. No nav, no footers, just the title and the text under each heading.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --test test/unit/*.test.js test/integration/*.test.js",
    "test:unit": "node --test test/unit/*.test.js",
    "test:integration": "node --test test/integration/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include=src/**/*.js test/unit/*.test.js test/integration/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "web-scraping",
    "content-extraction",
    "llm",
    "rag",
    "ai",
    "html-parser"
  ],
  "author": "Raccoon254",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.2.0",
    "fastify": "^5.8.4",
    "undici": "^8.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
